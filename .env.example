# ===== REQUIRED: Google Gemini LLM =====
GEMINI_API_KEY=your_gemini_api_key_here
MODEL_NAME=gemini-2.0-flash-exp

# ===== REQUIRED: HuggingFace Embeddings API =====
# Get key at: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_huggingface_token_here
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===== DATA PATHS =====
DOCUMENT_PATH=data/data.jsonl
USER_DATA_PATH=data/data.json
COURSES_PATH=data/courses.json
LEARNING_PATHS_PATH=data/learning_paths.json
COURSE_LEVELS_PATH=data/course_levels.json
TUTORIALS_PATH=data/tutorials.json

# ===== RAG CONFIGURATION =====
TOP_K=3
RETRIEVE_MIN_SCORE=0.4
MAX_CONTEXT_WORDS=400

# ===== OPTIONAL: Use Local Embeddings Instead of HF API =====
# Set to "true" to use sentence-transformers locally (slower, no API key needed)
# USE_LOCAL_EMBEDDINGS=false

# ===== MODEL CACHE (Docker/Railway) =====
TRANSFORMERS_CACHE=/app/models
HF_HOME=/app/models
TORCH_HOME=/app/models